{% extends 'base.html.twig' %}

{% block body %}

<div class="container py-4">

    <div class="card">
        <div class="card-body">

            <h1>{{ job.titre }}</h1>
            <h5>{{ job.entreprise }}</h5>

            <hr>

            <p>{{ job.description }}</p>

            <a href="{{ job.application_link }}" class="btn btn-primary">
                Apply
            </a>

        </div>
    </div>

</div>

{% endblock %}