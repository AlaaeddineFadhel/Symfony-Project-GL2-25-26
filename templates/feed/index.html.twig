{% extends 'base.html.twig' %}

{% block title %}Feed{% endblock %}

{% block body %}

<h1>Meet INSATiens</h1>

{# Floating create post button + modal for logged in users #}
{% if app.user %}
    <div style="position:fixed; right:24px; bottom:24px; z-index:1050;">
        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#postModal">+ Post</button>
    </div>

    <div class="modal fade" id="postModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Créer un post</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form method="POST" action="{{ path('app_post_create') }}">
                    <div class="modal-body">
                        <textarea name="content" class="form-control" rows="4" placeholder="Share an update..." required></textarea>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Post</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
{% endif %}

<div class="marquee-track">
    {% for profile in profiles %}
        <div class="profile-card">
            <h3>{{ profile.prenom }} {{ profile.nom }}</h3>
            <p>{{ profile.tagline }}</p>
        </div>
    {% endfor %}
</div>

<h1>Jobs</h1>

<div class="row">
    {% for job in jobs %}
        <div class="col-md-4 mb-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body d-flex flex-column">
                    <h5>{{ job.titre }}</h5>
                    <div class="text-muted small mb-2">
                        {{ job.jobType.value }} • {{ job.jobMode.value }}
                    </div>
                    <p class="flex-grow-1">{{ job.description|slice(0, 100) }}...</p>
                    <a href="{{ path('job_detail', {id: job.id}) }}" class="btn btn-primary mt-auto">
                        View details
                    </a>
                </div>
            </div>
        </div>
    {% endfor %}
</div>

<h1>Internships</h1>

<div class="row">
    {% for job in internships %}
        <div class="col-md-4 mb-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body d-flex flex-column">
                    <h5>{{ job.titre }}</h5>
                    <div class="text-muted small mb-2">
                        {{ job.jobType.value }} • {{ job.jobMode.value }}
                    </div>
                    <p class="flex-grow-1">{{ job.description|slice(0, 100) }}...</p>
                    <a href="{{ path('job_detail', {id: job.id}) }}" class="btn btn-primary mt-auto">
                        View details
                    </a>
                </div>
            </div>
        </div>
    {% endfor %}
</div>

{% endblock %}