{% extends 'base.html.twig' %}

{% block title %}Alumini | Recherche{% endblock %}
{% block css %}
    <link rel="stylesheet" href="{{ asset("styles/recherche.css") }}">
{% endblock %}
{% block body %}
    <div class="container mt-4">
        <br>
        <br>
        <div class="container mt-4">

            {{ form_start(form, { attr: { class: 'mb-4' } }) }}
            <div class="row justify-content-center align-items-center g-2">

                <div class="col-12 col-md-6 col-lg-7">
                    {{ form_widget(form.query) }}
                </div>

                <div class="col-12 col-md-6 col-lg-3">
                    {{ form_widget(form.filter) }}
                </div>

                <div class="col-6 col-md-3 col-lg-2">
                    {{ form_widget(form.submit) }}
                </div>

            </div>
            {{ form_end(form) }}
            {# Search results if not founded  #}
        <div class="row justify-content-center mt-4">
            <div class="col-sm-12 col-md-8 col-lg-6">
                <div class="bg-white p-4 rounded shadow" id="search_results">
                    <p class="text-muted">Your search results will appear here...</p>
                </div>
            </div>
        </div>
            {# Search results if founded  #}

        <div class="row justify-content-center mt-3">
            <div class="col-auto">
                <nav aria-label="Search pagination">
                    <ul class="pagination" id="pagination">
                        <li class="page-item" id="prev-btn">
                            <a class="page-link" href="#" aria-label="Previous">&laquo;</a>
                        </li>
                        <div id="pagination_numbers" class="d-flex"></div>
                        <li class="page-item" id="next-btn">
                            <a class="page-link" href="#" aria-label="Next">&raquo;</a>
                        </li>
                    </ul>
                </nav>
            </div>
        </div>

    </div>

{% endblock %}

